{
  "$schema": "https://tauri.app/schema/config.json",
  "productName": "medicoapp",
  "version": "0.1.0",
  "identifier": "com.gerardwalsh.medicoapp",

  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../../frontend/dist"
  },

  "app": {
    "windows": [
      {
        "title": "medicoapp",
        "width": 800,
        "height": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
